# ===============================================
# Django Settings - Environment Variables
# ===============================================
# Copia este archivo a .env y personaliza los valores
# IMPORTANTE: El archivo .env NO debe subirse a git

# -----------------------------------------------
# DESARROLLO LOCAL
# -----------------------------------------------

# Debug mode - True para desarrollo, False para producción
DEBUG=True

# Secret key - Genera uno nuevo con:
# python -c "import secrets; print(''.join(secrets.choice('abcdefghijklmnopqrstuvwxyz0123456789!@#%^&*(-_=+)') for i in range(50)))"
SECRET_KEY=change-me-to-a-random-secret-key-min-50-chars

# Hosts permitidos (separados por comas, sin espacios)
# Desarrollo: localhost,127.0.0.1
# Producción: .onrender.com,tudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL
# Desarrollo (SQLite): sqlite:///db.sqlite3
# Producción (PostgreSQL): postgresql://user:password@host:5432/database
# Render auto-configura DATABASE_URL para PostgreSQL
DATABASE_URL=sqlite:///db.sqlite3

# CSRF Trusted Origins (separados por comas, sin espacios)
# Desarrollo: http://localhost:8000,http://127.0.0.1:8000
# Producción: https://tu-app.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Geolocalización - Restricción geográfica del servicio
# True = Desactivar verificación (desarrollo/testing) - permite acceso desde cualquier ubicación
# False = Activar restricción geográfica (producción) - solo ciudades habilitadas
SKIP_GEO_CHECK=True

# -----------------------------------------------
# PRODUCCIÓN EN RENDER
# -----------------------------------------------
# Configura estas variables en el dashboard de Render:
#
# DEBUG=False
# SECRET_KEY=<genera-uno-nuevo-diferente-al-local>
# ALLOWED_HOSTS=.onrender.com
# DATABASE_URL=<auto-generado-por-render>
# CSRF_TRUSTED_ORIGINS=https://tu-app.onrender.com
# SKIP_GEO_CHECK=False
# PYTHON_VERSION=3.12.0
