# Django Settings Template
# Copia este archivo a .env y cambia los valores

# Debug mode - True para desarrollo, False para producción
DEBUG=True

# Secret key - Genera uno nuevo con: python -c "import secrets; print(''.join(secrets.choice('abcdefghijklmnopqrstuvwxyz0123456789!@#%^&*(-_=+)') for i in range(50)))"
SECRET_KEY=change-me-to-a-random-secret-key-min-50-chars

# Hosts permitidos (separados por comas)
# Desarrollo: localhost,127.0.0.1
# Producción: .onrender.com,tudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL (opcional)
# SQLite (desarrollo): sqlite:///db.sqlite3
# PostgreSQL (producción): postgresql://user:password@host:5432/database
DATABASE_URL=sqlite:///db.sqlite3

# CSRF Trusted Origins (para desarrollo local)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Geolocalización - Restricción geográfica del servicio
# True = Saltarse verificación (desarrollo/testing) - permite acceso desde cualquier ubicación
# False = Activar restricción geográfica (producción) - solo ciudades habilitadas
SKIP_GEO_CHECK=True
